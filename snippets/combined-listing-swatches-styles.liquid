{%- doc -%}
  Shared styles for the Combined Listings product-page and product-card swatch blocks.

  @example
  {% render 'combined-listing-swatches-styles' %}
{%- enddoc -%}

{% stylesheet %}
  .cl-swatches {
    display: block;
    width: 100%;
  }

  .cl-swatches__label {
    display: block;
    margin-block-end: var(--margin-3xs, 4px);
    font-size: var(--font-paragraph-small--size);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .cl-swatches__label-value {
    color: var(--color-foreground);
    font-weight: var(--font-weight-semibold);
  }

  .cl-swatches__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--cl-swatch-gap, 8px);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .cl-swatches__item {
    position: relative;
    display: inline-flex;
  }

  .cl-swatch-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 2px;
    background: none;
    cursor: pointer;
    border: none;
    border-radius: calc(var(--cl-swatch-radius) + 2px);
    -webkit-tap-highlight-color: transparent;
  }

  .cl-swatch-trigger:focus-visible {
    outline: var(--focus-outline-width) solid var(--focus-outline-color, currentColor);
    outline-offset: var(--focus-outline-offset, 2px);
  }

  .cl-swatch {
    display: block;
    width: var(--cl-swatch-size, 28px);
    height: var(--cl-swatch-size, 28px);
    border-radius: var(--cl-swatch-radius, 50%);
    background: var(--cl-swatch-background) center / cover no-repeat;
    /* No border by default; hover/selected states below make it visible. */
    border: var(--cl-swatch-border-width, 1px) solid transparent;
  }

  /* Hover: lighter grey border. Skipped on the selected swatch, which keeps its solid border. */
  .cl-swatch-trigger:hover .cl-swatch:not(.cl-swatch--empty) {
    border-color: rgb(var(--color-foreground-rgb) / 0.25);
  }

  .cl-swatch--empty {
    /* Placeholder dot (no image/color resolved) always needs a visible border to read as a shape. */
    border-color: rgb(var(--color-foreground-rgb) / var(--style-border-swatch-opacity, 0.2));
    background: rgb(var(--color-foreground-rgb) / 0.05);
  }

  .cl-swatch-trigger--active .cl-swatch {
    border-color: var(--color-foreground);
  }

  .cl-swatch--crossed-out {
    position: relative;
  }

  .cl-swatch--crossed-out::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      to top right,
      transparent calc(50% - 1px),
      rgb(var(--color-foreground-rgb) / 0.6) 50%,
      transparent calc(50% + 1px)
    );
  }

  .cl-swatch--faded {
    opacity: 0.4;
  }

  .cl-swatches__below-text {
    margin: var(--margin-2xs, 8px) 0 0;
    font-size: var(--font-paragraph-small--size);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    text-align: center;
  }

  /* Tooltip: rendered via the native Popover API so it escapes any ancestor
     `overflow: hidden` (product cards clip their gallery/content) and always
     renders in the top layer, which also keeps it clear of mobile viewport edges. */
  .cl-tooltip {
    position: fixed;
    max-inline-size: min(240px, calc(100vw - 32px));
    padding: var(--padding-2xs, 6px) var(--padding-xs, 10px);
    margin: 0;
    background: var(--cl-tooltip-bg);
    color: var(--cl-tooltip-color);
    font-size: var(--cl-tooltip-font-size, 13px);
    line-height: 1.3;
    border: var(--style-border-popover, 1px solid rgb(var(--color-foreground-rgb) / 0.1));
    border-radius: var(--style-border-radius-popover, 6px);
    box-shadow: var(--shadow-popover);
    inset: unset;
    top: max(8px, min(calc(var(--cl-tooltip-anchor-top, 0) * 1px), calc(100vh - 40px)));
    left: max(8px, min(calc(var(--cl-tooltip-anchor-left, 0) * 1px), calc(100vw - 248px)));
  }

  .cl-tooltip:popover-open {
    display: block;
  }

  @media (prefers-reduced-motion: no-preference) {
    .cl-tooltip {
      transition: opacity 0.15s var(--ease-out-quad, ease-out);
    }
  }
{% endstylesheet %}
